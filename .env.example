# ═══════════════════════════════════════════════════════════════════
# AI Image Studio — 환경 설정 템플릿
# ═══════════════════════════════════════════════════════════════════
# 사용법:
#   1) 이 파일을 `.env` 로 복사: `copy .env.example .env` (Windows)
#   2) 아래 ⚠️ 표시 항목을 본인 환경에 맞게 수정
#   3) docs/setup.md 가이드 참고
# ═══════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────
# ⚠️ 필수 — ComfyUI 경로
# ───────────────────────────────────────────────────────────────────
# Headless 모드 (권장 · 콘솔 창 0개): 아래 4개 모두 설정 시 venv python 직접 호출.
# 하나라도 비면 Electron GUI 폴백 (창 뜸).

# (1) ComfyUI 의 venv python.exe 경로
COMFYUI_PYTHON=C:/ComfyUI/.venv/Scripts/python.exe

# (2) ComfyUI Desktop 의 main.py 경로
#     보통: %LocalAppData%/Programs/@comfyorgcomfyui-electron/resources/ComfyUI/main.py
COMFYUI_MAIN_PY=C:/Users/{USERNAME}/AppData/Local/Programs/@comfyorgcomfyui-electron/resources/ComfyUI/main.py

# (3) ComfyUI extra_models_config.yaml (모델 폴더 인식)
#     보통: %AppData%/ComfyUI/extra_models_config.yaml
COMFYUI_EXTRA_PATHS_CONFIG=C:/Users/{USERNAME}/AppData/Roaming/ComfyUI/extra_models_config.yaml

# (4) ComfyUI 모델 root 폴더 (--base-directory 인자)
#     표준 구조 (checkpoints/, vae/, clip/, loras/, ...) 자동 인식
COMFYUI_BASE_DIR=C:/ComfyUI


# ───────────────────────────────────────────────────────────────────
# 옵션 — Electron GUI 폴백 (Headless 4 키 중 하나라도 비었을 때만 사용)
# ───────────────────────────────────────────────────────────────────
# COMFYUI_EXECUTABLE=C:/Users/{USERNAME}/AppData/Local/Programs/@comfyorgcomfyui-electron/ComfyUI.exe
# COMFYUI_MODELS_PATH=C:/ComfyUI/models


# ───────────────────────────────────────────────────────────────────
# ComfyUI 동작 옵션
# ───────────────────────────────────────────────────────────────────
COMFYUI_URL=http://127.0.0.1:8000
# 이미지 생성 idle 시간(분) 후 ComfyUI 자동 종료 (VRAM 절약)
COMFYUI_AUTO_SHUTDOWN_MINUTES=10
# ComfyUI dispatch 실패 시 mock-seed:// URL 로 완주할지 여부.
# 운영은 false (실제 에러 노출). UI 개발/테스트 시 true 면 ComfyUI 없이도 흐름 확인 가능.
COMFY_MOCK_FALLBACK=false


# ───────────────────────────────────────────────────────────────────
# ⚠️ 필수 — Ollama 경로 + 모델
# ───────────────────────────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434
# 프롬프트 업그레이드 모델 (gemma4-un · think=False 필수, reasoning 모델)
OLLAMA_MODEL=gemma4-un

# 옵션 — Ollama 수동 시작/종료 토글 활성화
# 설정하면 설정 패널에서 Ollama 켜기/끄기 가능 (기본은 OS 시작 시 자동)
# OLLAMA_EXECUTABLE=C:/Users/{USERNAME}/AppData/Local/Programs/Ollama/ollama.exe


# ───────────────────────────────────────────────────────────────────
# 옵션 — LLM 폴백 (Ollama 실패 시 Claude CLI)
# ───────────────────────────────────────────────────────────────────
# Claude CLI 가 PATH 에 있으면 "claude" 그대로, 아니면 절대 경로
CLAUDE_CLI_PATH=claude
LLM_FALLBACK_ENABLED=true


# ───────────────────────────────────────────────────────────────────
# 하드웨어
# ───────────────────────────────────────────────────────────────────
# 사용자의 GPU VRAM 총량 (GB) — 헤더 모니터링 + swap 임계치 계산
VRAM_TOTAL_GB=16.0


# ───────────────────────────────────────────────────────────────────
# 옵션 — LTX-2.3 Video i2v VRAM 16GB 대응
# ───────────────────────────────────────────────────────────────────
# 기본 fp8 체크포인트가 너무 크면 (29GB) Kijai 축소 variant 사용:
# LTX_UNET_NAME=ltx-2.3-22b-dev_transformer_only_fp8_scaled.safetensors


# ───────────────────────────────────────────────────────────────────
# Backend 서버
# ───────────────────────────────────────────────────────────────────
# ComfyUI(8000) 충돌 회피 — backend 는 8001 기본
APP_HOST=127.0.0.1
APP_PORT=8001
# 다중 frontend origin 은 콤마 (예: http://localhost:3000,http://localhost:3001)
# localhost ↔ 127.0.0.1 자동 대응
FRONTEND_URL=http://localhost:3000


# ───────────────────────────────────────────────────────────────────
# 데이터 저장 (상대 경로 = backend/ 기준)
# ───────────────────────────────────────────────────────────────────
HISTORY_DB_PATH=../data/history.db
OUTPUT_IMAGE_PATH=../data/images
UPLOAD_PATH=../data/uploads
WORKFLOWS_PATH=./workflows
