# ===========================================
# AI Image Studio 환경 설정
# 이 파일을 .env로 복사한 후 경로를 수정하세요
# ===========================================

# ComfyUI 설정
# Desktop 설치본 기본 포트 8000. 원본 ComfyUI(8188) 사용 시 값만 교체
COMFYUI_URL=http://127.0.0.1:8000
COMFYUI_EXECUTABLE=C:/Users/{username}/AppData/Local/Programs/@comfyorgcomfyui-electron/ComfyUI.exe
COMFYUI_MODELS_PATH=C:/Users/{username}/ComfyUI/models
COMFYUI_AUTO_SHUTDOWN_MINUTES=10

# Ollama 설정
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4-un
# Ollama 수동 시작용 실행 파일 경로 (선택 — 설정 시 설정 패널에서 시작/종료 가능)
# OLLAMA_EXECUTABLE=C:/Users/{username}/AppData/Local/Programs/Ollama/ollama.exe

# 앱 설정
# ComfyUI(8000)과 충돌 회피를 위해 백엔드는 8001 사용
APP_HOST=127.0.0.1
APP_PORT=8001
# 다중 프론트 origin 은 콤마로 구분 (예: http://localhost:3000,http://localhost:3001)
# 브라우저는 localhost ≠ 127.0.0.1 로 취급하나 백엔드에서 자동 대응함
FRONTEND_URL=http://localhost:3000

# 데이터 저장 경로
HISTORY_DB_PATH=./data/history.db
OUTPUT_IMAGE_PATH=./data/images
